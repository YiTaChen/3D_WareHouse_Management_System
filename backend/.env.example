# Backend runtime
PORT_LOCAL=3002

# Optional single-value database config for new setups.
# To use this explicitly, set DB_ENV=database_url or leave DB_ENV unset.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/warehouse_dev

# Legacy split settings are still supported for backward compatibility.
# Use local for a developer machine, cloud for a deployed backend such as Render.
DB_ENV=local

# Local PostgreSQL example
PG_HOST_LOCAL=localhost
PG_PORT_LOCAL=5432
PG_DATABASE_LOCAL=warehouse_dev
PG_USER_LOCAL=postgres
PG_PASSWORD_LOCAL=postgres
PG_DIALECT_LOCAL=postgres

# Cloud PostgreSQL example
# Keep real cloud database credentials in Render environment variables or
# another secret manager. Do not commit them to GitHub.
PG_HOST=
PG_PORT=5432
PG_DATABASE=
PG_USER=
PG_PASSWORD=
PG_DIALECT=postgres

# Optional. Set this to true only when your hosted PostgreSQL requires SSL.
# PG_SSL=true
