# Backend runtime
PORT_LOCAL=3002

# Use local for a developer machine, cloud for a deployed backend such as Render.
DB_ENV=local

# Local PostgreSQL example
PG_HOST_LOCAL=localhost
PG_PORT_LOCAL=5432
PG_DATABASE_LOCAL=warehouse_dev
PG_USER_LOCAL=postgres
PG_PASSWORD_LOCAL=postgres
PG_DIALECT_LOCAL=postgres

# Cloud PostgreSQL example
# Keep real cloud database credentials in Render environment variables or
# another secret manager. Do not commit them to GitHub.
PG_HOST=
PG_PORT=5432
PG_DATABASE=
PG_USER=
PG_PASSWORD=
PG_DIALECT=postgres

