# Frontend API configuration
#
# New clones do not need this file for local development because the app
# defaults to http://localhost:3002 when VITE_API_BASE_URL is not set.

VITE_API_BASE_URL=http://localhost:3002

# Optional hosted backend API. This is a public HTTP API endpoint, not a
# PostgreSQL connection string or secret.
VITE_API_BASE_URL_AA=https://threed-warehouse-management-system.onrender.com

# Use this only when you want the frontend to default to the hosted backend
# without replacing VITE_API_BASE_URL directly.
# VITE_API_TARGET=cloud

