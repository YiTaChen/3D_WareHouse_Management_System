{
  "name": "r3f-g-ver2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite",
    "dev:backend": "npm --prefix backend start",
    "dev:all": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "setup:all": "npm install && npm --prefix backend install",
    "build": "vite build",
    "lint": "eslint .",
    "test:conveyor-layout": "node --test src/conveyors/conveyorLayout.test.js",
    "test:conveyor-layout-store": "node --test src/stores/conveyorLayoutStore.test.js",
    "test:mission-builder": "node --test src/missions/builders/missionBuilderCore.test.js",
    "test:mission-production-factory": "node --test src/missions/builders/productionMissionFactory.test.js",
    "test:mission-runner": "node --test src/missions/runtime/missionRunner.test.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-three/cannon": "^6.6.0",
    "@react-three/drei": "^10.0.8",
    "@react-three/fiber": "^9.1.2",
    "immer": "^10.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.176.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "vite": "^6.3.5"
  }
}
